{
    "AcceptsRequests":true,
    "HostInfo":{
        "ServerName":"ICServer",
        "AppVersion":"3.27.5",
        "Additional":{}
    },
    "Logging":{
        "type":"stdout",
        "retryDelaySeconds":5,
        "retryAttempts":3,
        "path":"logs/api.log"
    },
    "ServerConfig":{
        "FileCachingEnabled":false,
        "JSONCachingEnabled":false,
        "ChunkCachingEnabled":false,
        "StringFilteringEnabled":true,
        "LoggingRateLimit":120,
        "ConfigReloadRateLimit":120,
        "Control":{
            "WorkingDirectory":".",
            "CacheFolderName":"cache"
        }
    }
}